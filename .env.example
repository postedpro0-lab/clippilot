# Copy to .env for local runs. In GitHub Actions these are "Secrets" instead.
# Leave blank any platform you're not posting to.

# ---- YouTube Data API (OAuth) ----
# Get these by running: python scripts/get_youtube_token.py
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ---- Instagram Graph API ----
# IG_USER_ID = your Instagram Business/Creator account id (numeric)
# IG_ACCESS_TOKEN = long-lived access token (60 days; auto-refresh handled)
IG_USER_ID=
IG_ACCESS_TOKEN=

# ---- TikTok Content Posting API ----
# Only needed once your developer app is approved.
TIKTOK_ACCESS_TOKEN=

# ---- Snapchat Public Profile / Spotlight API (OAuth) ----
# Needs an approved Snap Business API app + a Public Profile.
# CLIENT_ID/SECRET from your Snap app; REFRESH_TOKEN from the OAuth flow
# (scripts/get_snapchat_token.py); PROFILE_ID is your Public Profile id.
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=
SNAPCHAT_REFRESH_TOKEN=
SNAPCHAT_PROFILE_ID=
# (optional) a static token instead of OAuth refresh:
SNAPCHAT_ACCESS_TOKEN=

# ---- Hosting for IG/TikTok (they pull video from a public URL) ----
# A GitHub repo "owner/name" used to publish clips as public release assets.
# Defaults to the repo the Action runs in.
PUBLIC_REPO=
GITHUB_TOKEN=
